rules_version = '2';
// ============================================================================
//  MOODCHAT — Firestore Security Rules
//  NOTE: This app authenticates with Supabase (Email OTP), not Firebase Auth.
//  Because there is no Firebase Auth token, request.auth is null.
//
//  >>> CHOOSE ONE OF THE TWO MODES BELOW <<<
//
//  MODE A (DEV / DEMO — quick start, NOT for real production):
//    Open read/write so the Supabase-only client can work immediately.
//
//  MODE B (PRODUCTION — recommended):
//    Mint a Firebase Custom Token from your Supabase session inside the
//    Netlify function and call signInWithCustomToken() in the app, so that
//    request.auth.uid === the MOODCHAT uid. Then enable the locked-down rules.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- MODE A : DEV / DEMO (uncomment to use) --------
    // match /{document=**} {
    //   allow read, write: if true;   // ⚠️ anyone can read/write — demo only
    // }

    // -------- MODE B : PRODUCTION (requires Firebase custom-token sign-in) --------
    function signedIn() { return request.auth != null; }
    function isUser(uid) { return signedIn() && request.auth.uid == uid; }

    // users: anyone signed-in can read profiles (for search); only owner writes own doc
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isUser(uid);
      match /fcmTokens/{token}    { allow read, write: if isUser(uid); }
    }

    // chat requests: sender creates; receiver/sender can read; only receiver updates status
    match /chatRequests/{reqId} {
      allow read:   if signedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if signedIn() && request.auth.uid == request.resource.data.fromUid;
      allow update: if signedIn() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      allow delete: if false;
    }

    // chats: only members may read/write the chat and its sub-collections
    match /chats/{chatId} {
      function member() { return signedIn() && request.auth.uid in resource.data.members; }
      function memberNew() { return signedIn() && request.auth.uid in request.resource.data.members; }
      allow read:   if member();
      allow create: if memberNew();
      allow update: if member() || memberNew();

      match /messages/{msgId} {
        allow read:   if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow update: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow delete: if false;
      }
      match /nicknames/{userId} {
        allow read, write: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    // calls metadata (signaling lives in RTDB, but call history may be in chats/messages)
    match /calls/{callId} {
      allow read, write: if signedIn();
    }
  }
}
